{
  "name": "example-generic",
  "version": "0.1.0",
  "description": "Minimal sample recipe for exercising the Codex migration framework end-to-end.",
  "source": {
    "language": "generic",
    "framework": "generic"
  },
  "target": {
    "language": "generic",
    "framework": "generic"
  },
  "tier": "auto",
  "domains": [
    {
      "name": "core",
      "patterns_file": "patterns/core.patterns.json",
      "priority": 1
    },
    {
      "name": "interface",
      "patterns_file": "patterns/interface.patterns.json",
      "priority": 2
    },
    {
      "name": "integration",
      "patterns_file": "patterns/integration.patterns.json",
      "priority": 3
    },
    {
      "name": "tests",
      "patterns_file": "patterns/tests.patterns.json",
      "priority": 4
    }
  ],
  "domain_ordering": {
    "core": [],
    "integration": [
      "core"
    ],
    "interface": [
      "core",
      "integration"
    ],
    "tests": [
      "core",
      "integration",
      "interface"
    ]
  },
  "foundation": {
    "ast_tool": "builtin:generic-tier2-foundation"
  },
  "samples": {
    "tier2_source_path": "sample-source",
    "expected_domains": [
      "core",
      "interface",
      "integration",
      "tests"
    ]
  },
  "verification": {
    "custom_checks": [
      {
        "name": "api-contract",
        "command": "bash verify/api-contract.sh",
        "required": false
      },
      {
        "name": "smoke",
        "command": "python3 verify/smoke.py",
        "required": false
      }
    ]
  }
}
